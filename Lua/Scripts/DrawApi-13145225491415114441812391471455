local DrawApi = {}

function DrawApi:DrawLine(from, to, mainColor, transparency, border)
    local ApiGui = Instance.new("ScreenGui")
    ApiGui.Parent = game:GetService("CoreGui")
    ApiGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local Line = {
        From = from or Vector2.new(0, 0),
        To = to or Vector2.new(0, 0),
        Color = mainColor or Color3.fromRGB(255, 255, 255),
        Transparency = transparency or 0,
        Border = border or true,
        Thickness = 1,
    }

    local frame = Instance.new("Frame")
    frame.Parent = ApiGui

    local delta = Line.To - Line.From
    local length = delta.Magnitude
    local angle = math.atan2(delta.Y, delta.X)
    frame.Size = UDim2.fromOffset(length, Line.Thickness)
    frame.Position = UDim2.fromOffset((Line.From.X + Line.To.X) / 2, (Line.From.Y + Line.To.Y) / 2)
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.Rotation = math.deg(angle)
    frame.BackgroundColor3 = Line.Color
    frame.BackgroundTransparency = Line.Transparency
    frame.BorderSizePixel = Line.Border and 1 or 0
    frame.BorderColor3 = Color3.fromRGB(0, 0, 0)
    frame.Visible = true

    local DrawingLine = {}
    DrawingLine.Frame = frame
    DrawingLine.Line = Line

    function DrawingLine:Move(newFrom, newTo)
        self.Line.From = newFrom or self.Line.From
        self.Line.To = newTo or self.Line.To

        local delta = self.Line.To - self.Line.From
        local length = delta.Magnitude
        local angle = math.atan2(delta.Y, delta.X)
        self.Frame.Size = UDim2.fromOffset(length, self.Line.Thickness)
        self.Frame.Position = UDim2.fromOffset((self.Line.From.X + self.Line.To.X) / 2, (self.Line.From.Y + self.Line.To.Y) / 2)
        self.Frame.Rotation = math.deg(angle)
    end

    function DrawingLine:UpdateProperties(props)
       if props.Color then self.Line.Color = props.Color end
        if props.Transparency ~= nil then self.Line.Transparency = props.Transparency end
        if props.Border ~= nil then self.Line.Border = props.Border end
        if props.Visible == nil then self.Frame.Visible = true else self.Frame.Visible = props.Visible end

        local delta = self.Line.To - self.Line.From
        local length = delta.Magnitude
        local angle = math.atan2(delta.Y, delta.X)
        self.Frame.Size = UDim2.fromOffset(length, self.Line.Thickness)
        self.Frame.Position = UDim2.fromOffset((self.Line.From.X + self.Line.To.X)/2, (self.Line.From.Y + self.Line.To.Y)/2)
        self.Frame.Rotation = math.deg(angle)
        self.Frame.BackgroundColor3 = self.Line.Color
        self.Frame.BackgroundTransparency = self.Line.Transparency
        self.Frame.BorderSizePixel = self.Line.Border and 1 or 0
    end

    function DrawingLine:DeleteLine()
        if self.Frame then
            self.Frame:Destroy()
            self.Frame = nil
            self.Line = nil
        end
    end

    return DrawingLine
end

function DrawApi:DrawCircle(properties)
    local ApiGui = Instance.new("ScreenGui")
    ApiGui.Parent = game:GetService("CoreGui")
    ApiGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local CircleDrawing = {
        pos = properties.Pos or Vector2.new(0, 0),
        radius = properties.Radius or 50,
        color = properties.Color or Color3.fromRGB(255, 255, 255),
        border = properties.Border or false,
        zindex = properties.ZIndex,
    }

    local size = CircleDrawing.radius * 2

    local DrawingCircle = {}

    local function createCircleFrame(option)
        local frame = Instance.new("Frame")
        frame.BackgroundTransparency = 1
        frame.BorderSizePixel = 0
        frame.AnchorPoint = Vector2.new(0.5, 0.5)
        frame.Size = UDim2.fromOffset(
            size + (option.ExtraPixels or 0),
            size + (option.ExtraPixels or 0)
        )
        frame.Position = UDim2.fromOffset(
            CircleDrawing.pos.X,
            CircleDrawing.pos.Y
        )
        frame.Parent = ApiGui

        if CircleDrawing.zindex ~= nil then
            frame.ZIndex = CircleDrawing.zindex
        end

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = frame

        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 1
        stroke.Color = option.StrokeColor
        stroke.Parent = frame

        return frame, stroke
    end

    local borderFrame, borderStroke
    if CircleDrawing.border then
        borderFrame, borderStroke = createCircleFrame({
            ExtraPixels = 1,
            StrokeColor = Color3.fromRGB(0, 0, 0)
        })
    end

    local mainFrame, mainStroke = createCircleFrame({
        ExtraPixels = 0,
        StrokeColor = CircleDrawing.color
    })

    DrawingCircle.MainFrame = mainFrame
    DrawingCircle.MainStroke = mainStroke
    DrawingCircle.BorderFrame = borderFrame
    DrawingCircle.BorderStroke = borderStroke
    DrawingCircle.Properties = CircleDrawing

    function DrawingCircle:UpdateProperties(properties)
        if properties.Pos then
            self.Properties.pos = properties.Pos
            self.MainFrame.Position = UDim2.fromOffset(properties.Pos.X, properties.Pos.Y)
            if self.BorderFrame then
                self.BorderFrame.Position = UDim2.fromOffset(properties.Pos.X, properties.Pos.Y)
            end
        end
        if properties.Radius then
            self.Properties.radius = properties.Radius
            local newSize = properties.Radius * 2
            self.MainFrame.Size = UDim2.fromOffset(newSize, newSize)
            if self.BorderFrame then
                self.BorderFrame.Size = UDim2.fromOffset(newSize + 1, newSize + 1)
            end
        end
        if properties.Color then
            self.Properties.color = properties.Color
            self.MainStroke.Color = properties.Color
        end
        if properties.Border ~= nil then
            self.Properties.border = properties.Border
            if properties.Border and not self.BorderFrame then
                local bf, bs = createCircleFrame({
                    ExtraPixels = 1,
                    StrokeColor = Color3.fromRGB(0, 0, 0)
                })
                self.BorderFrame = bf
                self.BorderStroke = bs
            elseif not properties.Border and self.BorderFrame then
                self.BorderFrame:Destroy()
                self.BorderFrame = nil
                self.BorderStroke = nil
            end
        end
        if properties.ZIndex then
            self.Properties.zindex = properties.ZIndex
            self.MainFrame.ZIndex = properties.ZIndex
            if self.BorderFrame then
                self.BorderFrame.ZIndex = properties.ZIndex
            end
        end
    end

    function DrawingCircle:DeleteCircle()
        if self.MainFrame then
            self.MainFrame:Destroy()
            self.MainFrame = nil
        end
        if self.BorderFrame then
            self.BorderFrame:Destroy()
            self.BorderFrame = nil
        end
        self.MainStroke = nil
        self.BorderStroke = nil
        self.Properties = nil
    end

    return DrawingCircle
end

function DrawApi:DrawSquare(properties)
    local ApiGui = Instance.new("ScreenGui")
    ApiGui.Parent = game:GetService("CoreGui")
    ApiGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local SquareDrawing = {
        pos = properties.Pos or Vector2.new(0, 0),
        size = properties.Size or Vector2.new(50, 50),
        color = properties.Color or Color3.fromRGB(255, 255, 255),
        transparency = properties.Transparency or 0,
        border = properties.Border or false,
        zindex = properties.ZIndex,
    }

    local DrawingSquare = {}

    local function createSquareFrame(option)
        local frame = Instance.new("Frame")
        frame.AnchorPoint = Vector2.new(0.5, 0.5)
        frame.Position = UDim2.fromOffset(
            SquareDrawing.pos.X,
            SquareDrawing.pos.Y
        )
        frame.Size = UDim2.fromOffset(
            SquareDrawing.size.X + (option.ExtraPixels or 0),
            SquareDrawing.size.Y + (option.ExtraPixels or 0)
        )
        frame.BackgroundTransparency = 1
        frame.BorderSizePixel = 0
        frame.Parent = ApiGui

        if SquareDrawing.zindex ~= nil then
            frame.ZIndex = SquareDrawing.zindex
        end

        local stroke
        if option.StrokeColor then
            stroke = Instance.new("UIStroke")
            stroke.Thickness = 1
            stroke.Color = option.StrokeColor
            stroke.Transparency = option.Transparency or 0
            stroke.Parent = frame
        end

        return frame, stroke
    end

    local borderFrame, borderStroke
    if SquareDrawing.border then
        borderFrame, borderStroke = createSquareFrame({
            ExtraPixels = 1,
            StrokeColor = Color3.fromRGB(0, 0, 0),
            Transparency = SquareDrawing.transparency
        })
    end

    local mainFrame, mainStroke = createSquareFrame({
        ExtraPixels = 0,
        StrokeColor = SquareDrawing.color,
        Transparency = SquareDrawing.transparency
    })

    DrawingSquare.MainFrame = mainFrame
    DrawingSquare.MainStroke = mainStroke
    DrawingSquare.BorderFrame = borderFrame
    DrawingSquare.BorderStroke = borderStroke
    DrawingSquare.Properties = SquareDrawing

    function DrawingSquare:UpdateProperties(properties)
        if properties.Pos then
            self.Properties.pos = properties.Pos
            self.MainFrame.Position = UDim2.fromOffset(properties.Pos.X, properties.Pos.Y)
            if self.BorderFrame then
                self.BorderFrame.Position = self.MainFrame.Position
            end
        end
        if properties.Size then
            self.Properties.size = properties.Size
            self.MainFrame.Size = UDim2.fromOffset(properties.Size.X, properties.Size.Y)
            if self.BorderFrame then
                self.BorderFrame.Size = UDim2.fromOffset(properties.Size.X + 1, properties.Size.Y + 1)
            end
        end
        if properties.Color then
            self.Properties.color = properties.Color
            if self.MainStroke then
                self.MainStroke.Color = properties.Color
            end
        end
        if properties.Transparency ~= nil then
            self.Properties.transparency = properties.Transparency
            if self.MainStroke then
                self.MainStroke.Transparency = properties.Transparency
            end
            if self.BorderStroke then
                self.BorderStroke.Transparency = properties.Transparency
            end
        end
        if properties.Border ~= nil then
            self.Properties.border = properties.Border
            if properties.Border and not self.BorderFrame then
                local bf, bs = createSquareFrame({
                    ExtraPixels = 1,
                    StrokeColor = Color3.fromRGB(0, 0, 0),
                    Transparency = self.Properties.transparency
                })
                self.BorderFrame = bf
                self.BorderStroke = bs
            elseif not properties.Border and self.BorderFrame then
                self.BorderFrame:Destroy()
                self.BorderFrame = nil
                self.BorderStroke = nil
            end
        end
        if properties.ZIndex then
            self.Properties.zindex = properties.ZIndex
            self.MainFrame.ZIndex = properties.ZIndex
            if self.BorderFrame then
                self.BorderFrame.ZIndex = properties.ZIndex
            end
        end
    end

    function DrawingSquare:DeleteSquare()
        if self.MainFrame then
            self.MainFrame:Destroy()
            self.MainFrame = nil
        end
        if self.BorderFrame then
            self.BorderFrame:Destroy()
            self.BorderFrame = nil
        end
        self.MainStroke = nil
        self.BorderStroke = nil
        self.Properties = nil
    end

    return DrawingSquare
end

return DrawApi
